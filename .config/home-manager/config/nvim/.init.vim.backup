syntax on

set exrc
set nopreviewwindow
set nohlsearch
set nopaste
set noerrorbells
set hidden
set backup
set backupdir=~/.backupdir//
set swapfile
set undofile
set undodir=~/.undodir
set noruler
set noshowcmd
set autoindent
set smartindent
set shiftwidth=2
set tabstop=2 softtabstop=2
set incsearch
set expandtab
set nowrap
set colorcolumn=110
set nofoldenable
set updatetime=50
set shortmess+=c
set noshowmode
set completeopt=menu,menuone,noselect
set signcolumn=yes
set rnu
set number
set termguicolors
set laststatus=3
set winbar=%f
set clipboard=unnamedplus
set scrolloff=15

let mapleader = " "

lua require'init'

let g:did_load_filetypes = 1

set termguicolors
let g:gruvbox_italic=1
" colo duskfox
colo tokyonight-night

source $HOME/.config/nvim/au.vim
source $HOME/.config/nvim/var.vim
source $HOME/.config/nvim/mappings.vim
